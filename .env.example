# ===========================================
# CONFIGURACAO DO SISTEMA DE RASTREAMENTO
# Copie este arquivo para .env e preencha
# ===========================================

# Supabase (obrigatorio)
VITE_SUPABASE_PROJECT_ID="seu_project_id_aqui"
VITE_SUPABASE_PUBLISHABLE_KEY="sua_anon_key_aqui"
VITE_SUPABASE_URL="https://seu_project_id.supabase.co"

# ===========================================
# AS CREDENCIAIS ABAIXO SAO CONFIGURADAS
# DIRETAMENTE NO PAINEL ADMIN DO SISTEMA:
#
# - Evolution API (URL + API Key)
#   → Admin > Instancias > Adicionar
#
# - Facebook Pixel (Pixel ID + Access Token)
#   → Admin > Pixels > Adicionar
#
# - Telegram Bot (Token do BotFather)
#   → Admin > Telegram > Registrar Bot
#
# Nao precisa colocar elas aqui no .env!
# ===========================================
